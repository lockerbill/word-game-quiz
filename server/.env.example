# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/alphabucks

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=*

# AI validation
AI_VALIDATION_ENABLED=true
AI_VALIDATION_PROVIDER=openai
AI_VALIDATION_TIMEOUT_MS=2500
AI_VALIDATION_MIN_CONFIDENCE=0.70
AI_VALIDATION_CACHE_TTL_SECONDS=604800

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
